{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev --port 3001",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/workers/midnight-hunter",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/workers/idle-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/workers/process-task",
      "schedule": "*/5 * * * *"
    }
  ]
}
