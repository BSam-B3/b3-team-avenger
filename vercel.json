{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev --port 3001",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/workers/midnight-hunter",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/workers/morning-brief",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/workers/weekly-condense",
      "schedule": "0 2 * * 0"
    }
  ]
}
